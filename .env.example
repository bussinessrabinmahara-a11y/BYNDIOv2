# ===========================================================================
# BYNDIO ENVIRONMENT VARIABLES TEMPLATE (VERCEL + SUPABASE)
# Instructions:
# 1. Create a new .env file: `cp .env.example .env`
# 2. Fill in the values from your Supabase, Vercel, and Razorpay accounts.
# 3. Add these same variables to Vercel Dashboard → Settings → Environment Variables
# ===========================================================================

# --- SUPABASE CONFIGURATION ---
# Get these from: Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (KEEP SECRET)

# --- RAZORPAY CONFIGURATION ---
# Get these from: Razorpay Dashboard -> Settings -> API Keys
# Leave empty for TEST MODE (all payments simulated)
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- CLOUDFLARE TURNSTILE (CAPTCHA) ---
# Get these from: Cloudflare Dashboard -> Turnstile
# Leave empty to bypass CAPTCHA during testing
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- EMAIL SERVICE (RESEND) ---
# Get these from: Resend.com
# Leave empty to skip email sending during testing
RESEND_API_KEY=
FROM_EMAIL=noreply@byndio.in

# --- LOGISTICS (SHIPROCKET) ---
# Get these from: Shiprocket Dashboard
# Leave empty to skip shipping integration during testing
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# --- ANALYTICS & MONITORING ---
VITE_GA_ID=
VITE_CLARITY_ID=
VITE_SENTRY_DSN=

# --- SYSTEM SETTINGS ---
NODE_ENV=production
VITE_APP_URL=https://your-site.vercel.app
