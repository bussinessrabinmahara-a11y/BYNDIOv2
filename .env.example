# BYNDIO Environment Variables Template
# Copy this file to .env and fill in the values

# --- PUBLIC / FRONTEND VARIABLES (VITE_ PREFIX) ---
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
VITE_GA_ID=G-XXXXXXXXXX
VITE_CLARITY_ID=your_clarity_project_id
VITE_SENTRY_DSN=your_sentry_dsn

# --- SERVER-SIDE VARIABLES (NETLIFY FUNCTIONS) ---
# Note: Netlify functions need these without the VITE_ prefix
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# --- OPTIONAL ---
NODE_ENV=development
