# ===========================================================================
# BYNDIO ENVIRONMENT VARIABLES TEMPLATE (PRODUCTION READY)
# Instructions:
# 1. Create a new .env file: `cp .env.example .env`
# 2. Fill in the values from your new Supabase, Netlify, and Razorpay accounts.
# ===========================================================================

# --- SUPABASE CONFIGURATION ---
# Get these from: Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (KEEP SECRET)

# --- RAZORPAY CONFIGURATION ---
# Get these from: Razorpay Dashboard -> Settings -> API Keys
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret (KEEP SECRET)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret (For payment sync)

# --- CLOUDFLARE TURNSTILE (CAPTCHA) ---
# Get these from: Cloudflare Dashboard -> Turnstile
VITE_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# --- EMAIL SERVICE (RESEND) ---
# Get these from: Resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=support@byndio.com

# --- LOGISTICS (SHIPROCKET) ---
# Get these from: Shiprocket Dashboard
SHIPROCKET_EMAIL=your-email@example.com
SHIPROCKET_PASSWORD=your-password

# --- ANALYTICS & MONITORING ---
VITE_GA_ID=G-XXXXXXXXXX
VITE_CLARITY_ID=your-clarity-id
VITE_SENTRY_DSN=your-sentry-dsn

# --- SYSTEM SETTINGS ---
NODE_ENV=production
VITE_APP_URL=https://your-site.netlify.app
